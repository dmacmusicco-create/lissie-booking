# Copy this file: cp .env.example .env

PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_CALENDAR_EMAIL=dmac.music.co@gmail.com
GOOGLE_REFRESH_TOKEN=

GMAIL_USER=dmac.music.co@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
BOOKING_NOTIFICATION_EMAIL=Derrick.mackey@lissiemarionshowproductions.com

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change_this_to_something_long_and_random
CRON_SECRET=another_random_string_for_cron_auth

# 1st and 15th of every month at 2pm UTC (every ~2 weeks)
NEWSLETTER_CRON=0 14 1,15 * *
CACHE_TTL_MS=120000
